# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key   # server-only, never commit

# --- Groq (https://console.groq.com/keys) ---
GROQ_API_KEY=gsk_...your-key
# Optional override; defaults to meta-llama/llama-4-scout-17b-16e-instruct
GROQ_ROAST_MODEL=

# --- Site URL ---
# Used for OAuth redirects in non-production environments. Vercel sets VERCEL_URL automatically.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
